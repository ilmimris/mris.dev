---
export const prerender = true;

import { getCollection } from "astro:content";
import BlogArticle from "@/components/BlogArticle.astro";
import Card from "@/components/Card.astro";
import Navigation from "@/components/Navigation.astro";
import ViewCount from "@/components/ViewCount.astro";
import ViewCountLoader from "@/components/ViewCountLoader.astro";
import GradientLayout from "@/layouts/GradientLayout.astro";
import { formatDate, slugFromId, type BlogEntry } from "@/lib/content";

const posts: BlogEntry[] = await getCollection("blog");
const featured = posts.find((blog) => slugFromId(blog.id) === "memleak");
const top2 = posts.find((blog) => slugFromId(blog.id) === "covid19");
const top3 = posts.find((blog) => slugFromId(blog.id) === "wedding");
const pinned = new Set([featured, top2, top3].filter(Boolean).map((post) => slugFromId(post!.id)));
const sorted = posts
  .filter((post) => post.data.published)
  .filter((post) => !pinned.has(slugFromId(post.id)))
  .sort((a, b) => (b.data.date?.getTime() ?? Number.POSITIVE_INFINITY) - (a.data.date?.getTime() ?? Number.POSITIVE_INFINITY));
const columns = [0, 1, 2].map((column) =>
  sorted.filter((_, index) => index % 3 === column),
);
---

<GradientLayout title="Blogs">
  <div class="relative pb-16">
    <Navigation />
    <div class="px-6 pt-20 mx-auto space-y-8 max-w-7xl lg:px-8 md:space-y-16 md:pt-24 lg:pt-32">
      <div class="max-w-2xl mx-auto lg:mx-0">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-100 sm:text-4xl">Blogs</h2>
        <p class="mt-4 text-zinc-400">Some of the blogs are from work and my blogs.</p>
      </div>
      <div class="w-full h-px bg-zinc-800"></div>

      {featured && (
        <div class="grid grid-cols-1 gap-8 mx-auto lg:grid-cols-2">
          <Card>
            <a href={`/blogs/${slugFromId(featured.id)}`}>
              <article class="relative w-full h-full p-4 md:p-8">
                <div class="flex items-center justify-between gap-2">
                  <div class="text-xs text-zinc-100">
                    {featured.data.date ? <time datetime={featured.data.date.toISOString()}>{formatDate(featured.data.date)}</time> : <span>SOON</span>}
                  </div>
                  <span class="flex items-center gap-1 text-xs text-zinc-500">
                    <ViewCount collection="blogs" slug={slugFromId(featured.id)} value={0} />
                  </span>
                </div>
                <h2 id="featured-post" class="mt-4 mb-16 text-3xl font-bold text-zinc-100 group-hover:text-white sm:text-4xl font-display">
                  {featured.data.title}
                </h2>
                <div class="absolute bottom-4 md:bottom-8">
                  <p class="hidden text-zinc-200 hover:text-zinc-50 lg:block">Read more <span aria-hidden="true">&rarr;</span></p>
                </div>
              </article>
            </a>
          </Card>

          <div class="flex flex-col w-full gap-8 mx-auto border-t border-gray-900/10 lg:mx-0 lg:border-t-0">
            {[top2, top3].filter(Boolean).map((blog) => (
              <Card>
                <BlogArticle blog={blog!} views={0} />
              </Card>
            ))}
          </div>
        </div>
      )}

      <div class="hidden w-full h-px md:block bg-zinc-800"></div>

      <div class="grid grid-cols-1 gap-4 mx-auto lg:mx-0 md:grid-cols-3">
        {columns.map((blogs) => (
          <div class="grid grid-cols-1 gap-4">
            {blogs.map((blog) => (
              <Card>
                <BlogArticle blog={blog} views={0} />
              </Card>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>
  <ViewCountLoader />
</GradientLayout>
