---
export const prerender = true;

import { getCollection } from "astro:content";
import Card from "@/components/Card.astro";
import Navigation from "@/components/Navigation.astro";
import ViewCount from "@/components/ViewCount.astro";
import ViewCountLoader from "@/components/ViewCountLoader.astro";
import WorkArticle from "@/components/WorkArticle.astro";
import GradientLayout from "@/layouts/GradientLayout.astro";
import { formatDate, slugFromId, type WorkEntry } from "@/lib/content";

const works: WorkEntry[] = await getCollection("works");
const current = works.find((work) => slugFromId(work.id) === "spv2.sicepat");
const sorted = works
  .filter((work) => work.data.published)
  .filter((work) => slugFromId(work.id) !== (current ? slugFromId(current.id) : ""))
  .sort((a, b) => (b.data.from?.getTime() ?? Number.POSITIVE_INFINITY) - (a.data.from?.getTime() ?? Number.POSITIVE_INFINITY));
---

<GradientLayout title="Works">
  <div class="relative pb-16">
    <Navigation />
    <div class="px-6 pt-20 space-y-8 md:space-y-0 mx-auto max-w-7xl lg:px-8 md:pt-24 lg:pt-32">
      <div class="max-w-2xl mx-auto lg:mx-0 md:my-8 lg:my-16">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-100 sm:text-4xl">Works</h2>
        <p class="mt-4 text-zinc-400">
          Work experiences that I have been through. Some are from my full-time job and some are from my part-time job.
        </p>
      </div>
      <div class="w-full h-px bg-zinc-800"></div>

      {current && (
        <div class="grid grid-cols-1 w-full p-8 md:w-4/5 mx-auto justify-center">
          <Card>
            <a href={`/works/${slugFromId(current.id)}`}>
              <article class="relative w-full h-full p-4 md:p-8">
                <div class="flex items-center justify-between gap-2">
                  <div class="text-xs text-zinc-100">
                    {current.data.from ? <time datetime={current.data.from.toISOString()}>{formatDate(current.data.from)}</time> : <span>Now</span>}
                    {" - "}
                    {current.data.until && current.data.until !== "now" ? <time datetime={new Date(current.data.until).toISOString()}>{formatDate(current.data.until)}</time> : <span>Present</span>}
                  </div>
                  <span class="flex items-center gap-1 text-xs text-zinc-500">
                    <ViewCount collection="works" slug={slugFromId(current.id)} value={0} />
                  </span>
                </div>

                <h2 id="featured-post" class="mt-4 text-3xl font-bold text-zinc-100 group-hover:text-white sm:text-4xl font-display">
                  {current.data.position}
                </h2>
                <p class="mt-2 leading-8 duration-150 text-zinc-400 group-hover:text-zinc-300">
                  {current.data.company}
                </p>
                <div class="pt-2">
                  <p class="hidden text-zinc-200 hover:text-zinc-50 lg:block">Read more <span aria-hidden="true">&rarr;</span></p>
                </div>
              </article>
            </a>
          </Card>
        </div>
      )}

      <div class="w-full h-px md:block bg-zinc-800"></div>

      <div class="grid grid-cols-1 gap-8 md:gap-0 w-10/12 md:w-full lg:mx-0 mx-auto md:mt-0">
        {sorted.map((work) => (
          <div class="grid md:grid-cols-2">
            <div class="hidden md:flex md:flex-col w-full md:w-1/4 items-center ml-auto mr-4">
              <div class="w-px h-1/2 bg-zinc-800"></div>
              <div class="w-4 h-4 bg-zinc-500 rounded-full"></div>
              <div class="w-px h-1/2 bg-zinc-800"></div>
            </div>
            <div class="flex flex-col items-center -mt-8 md:hidden">
              <div class="w-px h-8 bg-slate-200"></div>
            </div>
            <div class="w-full md:w-3/4 md:mt-8">
              <Card>
                <WorkArticle work={work} views={0} />
              </Card>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
  <ViewCountLoader />
</GradientLayout>
