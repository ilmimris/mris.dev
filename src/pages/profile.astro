---
export const prerender = true;

import Card from "@/components/Card.astro";
import Navigation from "@/components/Navigation.astro";
import GradientLayout from "@/layouts/GradientLayout.astro";
import data from "@/data/profile.json";
import { getCollection } from "astro:content";
import { formatDate, slugFromId, type WorkEntry } from "@/lib/content";

const latestWorks: WorkEntry[] = (await getCollection("works"))
  .filter((work) => work.data.published)
  .sort((a, b) => {
    const aTime = a.data.from?.getTime() ?? 0;
    const bTime = b.data.from?.getTime() ?? 0;

    return bTime - aTime;
  })
  .slice(0, 3);
---

<GradientLayout title="Profile">
  <div class="relative pb-16">
    <Navigation />
    <div class="px-6 pt-20 mx-auto space-y-8 max-w-7xl lg:px-8 md:space-y-16 md:pt-24 lg:pt-32">
      <div class="max-w-2xl mx-auto lg:mx-0 md:my-8 lg:my-16">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-100 sm:text-4xl">Profile</h2>
        <p class="mt-4 text-zinc-400">Professional summary</p>
      </div>

      <div class="w-full h-px bg-zinc-800"></div>

      <div class="mx-auto lg:mx-0">
        <div class="grid grid-cols-1 gap-8 w-full">
          <Card>
            <div class="flex mx-auto flex-col lg:flex-row items-center">
              <div class="p-8">
                <div class="relative w-72 h-72 rounded-full overflow-hidden bg-[url('/pp.jpg')] bg-cover bg-right-top bg-no-repeat grayscale hover:grayscale-0"></div>
              </div>
              <div class="w-full p-8">
                <h2 class="text-3xl font-bold tracking-tight text-zinc-100 sm:text-4xl">
                  Muhammad Rafiul Ilmi Syarifudin
                </h2>
                <h3 class="mt-4 text-xl font-normal text-zinc-100">
                  Unit Head Process and Data Management & AI | Lead Software Engineer
                </h3>

                <p class="mt-4 text-zinc-400">
                  Results-oriented engineering and process management leader with over 7 years of experience building high-impact systems, improving operational workflows, and guiding data, infrastructure, and AI initiatives. Recent work includes directing data maturity assessments, Kubernetes migration planning, infrastructure cost optimization, automation platform enablement, fraud-detection chatbot implementation, and OCR/object recognition for document processing.
                </p>
                <p class="mt-4 text-zinc-400">
                  Proven leadership skills in managing engineers and cross-functional delivery across backend systems, business process documentation, platform operations, and AI-assisted automation. Strong hands-on background in Go, TypeScript, Python, MongoDB, PostgreSQL, Redis, Kafka, Docker, Kubernetes, GitLab CI, Terraform, LLMs, n8n, BPMN, and DMN.
                </p>
                <p class="mt-4 text-zinc-400">
                  "Success is not measured by lines of code, but by the problems solved and the value delivered."
                </p>
              </div>
            </div>
          </Card>
        </div>
      </div>
      <div class="w-full h-px bg-zinc-800"></div>

      <div class="flex flex-col gap-4">
        <div>
          <h2 class="text-2xl font-normal text-zinc-100">Latest Work</h2>
          <p class="mt-2 text-zinc-400">
            Recent roles and initiatives from my work timeline.
          </p>
        </div>

        <div class="grid w-full grid-cols-1 gap-8 lg:grid-cols-3">
          {latestWorks.map((work) => (
            <Card>
              <a href={`/works/${slugFromId(work.id)}`} class="block h-full">
                <article class="flex h-full flex-col p-8">
                  <div class="text-xs text-zinc-400">
                    {work.data.from ? <time datetime={work.data.from.toISOString()}>{formatDate(work.data.from)}</time> : <span>Now</span>}
                    {" - "}
                    {work.data.until && work.data.until !== "now" ? <time datetime={new Date(work.data.until).toISOString()}>{formatDate(work.data.until)}</time> : <span>Present</span>}
                  </div>
                  <h3 class="mt-4 text-xl font-medium text-zinc-100">
                    {work.data.position}
                  </h3>
                  <p class="mt-2 text-sm text-zinc-400">{work.data.company}</p>
                  <p class="mt-6 text-sm text-zinc-200">
                    Read more <span aria-hidden="true">&rarr;</span>
                  </p>
                </article>
              </a>
            </Card>
          ))}
        </div>
      </div>

      <div class="w-full h-px bg-zinc-800"></div>
      <h2 class="mt-4 text-2xl font-normal text-zinc-100">Skills</h2>

      <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-8">
        {data.map((item) => (
          <Card>
            <div class="p-8 font-normal text-zinc-100">
              <h3 class="mt-4 text-xl">{item.category}</h3>
              <ul class="font-light text-zinc-400">
                {item.skills.map((skill) => <li>{skill}</li>)}
              </ul>
            </div>
          </Card>
        ))}
      </div>

      <div class="w-full h-px bg-zinc-800"></div>

      <Card>
        <div class="p-8 text-center">
          <h2 class="text-2xl font-bold text-zinc-100">🧪 Playground</h2>
          <p class="mt-2 text-zinc-400">
            Explore my experiments, AI demos, and interactive tools.
          </p>
          <a
            href="https://playground.mris.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-6 px-6 py-3 text-sm font-medium text-white bg-zinc-100 rounded-lg hover:bg-zinc-200 transition-colors"
          >
            Visit Playground →
          </a>
        </div>
      </Card>
    </div>
  </div>
</GradientLayout>
