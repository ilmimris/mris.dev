---
import { MessageCircle, Send } from "@lucide/astro";
import type { CollectionName } from "@/lib/content";

const { collection, slug } = Astro.props as {
  collection: CollectionName;
  slug: string;
};
---

<section
  class="mx-auto max-w-2xl px-4 pb-16"
  data-comments
  data-collection={collection}
  data-slug={slug}
>
  <div class="border-t border-zinc-200 pt-10">
    <div class="flex items-center gap-3">
      <MessageCircle class="h-5 w-5 text-zinc-500" />
      <h2 class="font-display text-2xl font-semibold text-zinc-900">Comments</h2>
    </div>

    <div class="mt-6 space-y-4" data-comment-list>
      <p class="text-sm text-zinc-500" data-comment-empty>Loading comments...</p>
    </div>

    <form class="mt-8 space-y-4" data-comment-form>
      <div class="hidden" aria-hidden="true">
        <label>
          Website
          <input name="website" tabindex="-1" autocomplete="off" />
        </label>
      </div>

      <div class="grid gap-4 sm:grid-cols-[minmax(0,14rem)_1fr]">
        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Name</span>
          <input
            class="mt-2 w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none duration-200 placeholder:text-zinc-400 focus:border-zinc-900 focus:ring-2 focus:ring-zinc-900/10"
            name="name"
            type="text"
            maxlength="80"
            autocomplete="name"
            required
          />
        </label>

        <label class="block">
          <span class="text-sm font-medium text-zinc-700">Comment</span>
          <textarea
            class="mt-2 min-h-28 w-full resize-y rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none duration-200 placeholder:text-zinc-400 focus:border-zinc-900 focus:ring-2 focus:ring-zinc-900/10"
            name="message"
            maxlength="1000"
            required
          ></textarea>
        </label>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button
          class="inline-flex items-center gap-2 rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white duration-200 hover:bg-zinc-700 disabled:cursor-not-allowed disabled:bg-zinc-400"
          type="submit"
        >
          <Send class="h-4 w-4" />
          <span data-comment-submit-label>Post comment</span>
        </button>
        <p class="text-sm text-zinc-500" role="status" data-comment-status></p>
      </div>
    </form>
  </div>
</section>

<script>
  type Comment = {
    id: string;
    name: string;
    message: string;
    createdAt: string;
  };

  const sections = Array.from(
    document.querySelectorAll<HTMLElement>("[data-comments]"),
  );

  const formatDate = (value: string) =>
    Intl.DateTimeFormat(undefined, {
      dateStyle: "medium",
      timeStyle: "short",
    }).format(new Date(value));

  const renderComment = (comment: Comment) => {
    const article = document.createElement("article");
    article.className = "rounded-md border border-zinc-200 bg-white p-4";

    const header = document.createElement("div");
    header.className = "flex flex-wrap items-baseline justify-between gap-2";

    const name = document.createElement("h3");
    name.className = "text-sm font-semibold text-zinc-900";
    name.textContent = comment.name;

    const time = document.createElement("time");
    time.className = "text-xs text-zinc-500";
    time.dateTime = comment.createdAt;
    time.textContent = formatDate(comment.createdAt);

    const message = document.createElement("p");
    message.className = "mt-3 whitespace-pre-wrap text-sm leading-6 text-zinc-700";
    message.textContent = comment.message;

    header.append(name, time);
    article.append(header, message);

    return article;
  };

  const setStatus = (node: HTMLElement | null, message: string) => {
    if (node) node.textContent = message;
  };

  sections.forEach(async (section) => {
    const collection = section.dataset.collection;
    const slug = section.dataset.slug;
    const list = section.querySelector<HTMLElement>("[data-comment-list]");
    const empty = section.querySelector<HTMLElement>("[data-comment-empty]");
    const form = section.querySelector<HTMLFormElement>("[data-comment-form]");
    const status = section.querySelector<HTMLElement>("[data-comment-status]");
    const button = form?.querySelector<HTMLButtonElement>("button[type='submit']");
    const buttonLabel = section.querySelector<HTMLElement>(
      "[data-comment-submit-label]",
    );

    if (!collection || !slug || !list || !form) return;

    const showComments = (comments: Comment[]) => {
      list.replaceChildren();

      if (comments.length === 0) {
        const message = document.createElement("p");
        message.className = "text-sm text-zinc-500";
        message.textContent = "No comments yet. Start the thread.";
        list.append(message);
        return;
      }

      comments.forEach((comment) => list.append(renderComment(comment)));
    };

    try {
      const params = new URLSearchParams({ collection, slug });
      const response = await fetch(`/api/comments?${params.toString()}`);

      if (!response.ok) {
        throw new Error("Could not load comments.");
      }

      const payload = await response.json();
      showComments(Array.isArray(payload.comments) ? payload.comments : []);
    } catch {
      if (empty) empty.textContent = "Comments are unavailable right now.";
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const name = String(formData.get("name") ?? "").trim();
      const message = String(formData.get("message") ?? "").trim();
      const website = String(formData.get("website") ?? "").trim();

      if (!name || !message) {
        setStatus(status, "Name and comment are required.");
        return;
      }

      if (button) button.disabled = true;
      setStatus(buttonLabel, "Posting...");
      setStatus(status, "");

      try {
        const response = await fetch("/api/comments", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ collection, slug, name, message, website }),
        });

        const payload = await response.json().catch(() => ({}));

        if (!response.ok || !payload.comment) {
          throw new Error(payload.error ?? "Could not post this comment.");
        }

        const currentEmpty = list.querySelector("p.text-zinc-500");
        if (currentEmpty && list.children.length === 1) {
          list.replaceChildren();
        }

        list.append(renderComment(payload.comment));
        form.reset();
        setStatus(status, "Comment posted.");
      } catch (error) {
        setStatus(
          status,
          error instanceof Error ? error.message : "Could not post this comment.",
        );
      } finally {
        if (button) button.disabled = false;
        setStatus(buttonLabel, "Post comment");
      }
    });
  });
</script>
